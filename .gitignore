# Vendored OpenMLS Rust workspace — build-time input only.
# Ignore the whole workspace EXCEPT the openmls-wasm crate, which we modify
# (snapshot/restore bindings) and therefore keep in version control. The built
# artifact is committed separately in wasm/.
/openmls/*
!/openmls/openmls-wasm/
/openmls/openmls-wasm/target/
/openmls/openmls-wasm/pkg/

# Node / TypeScript
node_modules/
dist/
build/
*.tsbuildinfo
*.log
*.tgz

# OS
.DS_Store
